# LLM provider: "deepseek" or "claude"
PLATFORM=deepseek

# DeepSeek (used when PLATFORM=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic / Claude (used when PLATFORM=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8   # or a cheaper tier, e.g. claude-haiku-4-5

# Narration (optional). Defaults to the macOS `say` command.
# Use "none" on non-macOS platforms to render silent videos.
TTS_PROVIDER=say
TTS_VOICE=Samantha
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=

# Where the render worker lives
RENDER_WORKER_URL=http://localhost:3939

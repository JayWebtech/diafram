# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/diafram

# Object storage: "local" writes MP4s to disk, "r2" uses Cloudflare R2
STORAGE_BACKEND=local
STORAGE_DIR=.storage
RENDER_PORT=3939

# Only required when STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=            # optional custom endpoint
